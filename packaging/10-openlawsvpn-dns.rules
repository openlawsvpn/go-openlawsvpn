// Allow openlawsvpn-daemon to configure per-interface DNS via systemd-resolved
// without requiring a polkit authentication prompt.
//
// The daemon runs as the openlawsvpn system user (not as a logged-in session
// user) and needs to call org.freedesktop.resolve1 SetLinkDNS, SetLinkDomains,
// and RevertLink on the TUN interface it owns.

polkit.addRule(function(action, subject) {
    var dns_actions = [
        "org.freedesktop.resolve1.set-dns-servers",
        "org.freedesktop.resolve1.set-domains",
        "org.freedesktop.resolve1.set-default-route",
        "org.freedesktop.resolve1.revert",
    ];
    if (dns_actions.indexOf(action.id) >= 0 &&
            subject.user === "openlawsvpn") {
        return polkit.Result.YES;
    }
});
