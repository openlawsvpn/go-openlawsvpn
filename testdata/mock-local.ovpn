# mock-local.ovpn — test profile for the local mock server.
#
# Usage:
#   1. Start the mock server:
#        go run ./mock/mockserver
#      (or with CRV1 mode: MOCK_CRV1=1 go run ./mock/mockserver)
#
#   2. Connect the Go client:
#        sudo go run ./cmd/ovpn3 -config testdata/mock-local.ovpn -saml-token dGVzdA==
#
#   3. Connect the C++ client (for comparison):
#        sudo openlawsvpn-cli --config testdata/mock-local.ovpn --saml-token dGVzdA==
#
# The server generates a self-signed cert in memory, so the CA block below
# is a placeholder — client.go uses InsecureSkipVerify when the CA cannot be
# parsed, which is appropriate for local testing only.
#
# To use a real CA, start the server with CERT_DIR=/path/to/certs and replace
# the <ca> block with the contents of /path/to/certs/ca.crt.

client
dev tun
proto tcp-client
remote 127.0.0.1 4433
resolv-retry infinite
nobind
persist-key
persist-tun
verb 3

# random-hostname is NOT set here so 127.0.0.1 is used directly.

# No client certificate — AWS Client VPN with SAML does not use mutual TLS.
# auth-nocache

# The mock server generates a self-signed cert; disable verification for tests.
# Replace with a real <ca> block when CERT_DIR is used.
tls-client

<ca>
# Placeholder — replaced by actual CA cert when using CERT_DIR.
# Client will use InsecureSkipVerify if this cannot be parsed.
</ca>
